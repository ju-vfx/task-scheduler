### Create worker
POST http://localhost:8080/api/workers
Content-Type: application/json

{
    "host": "testhost",
    "port": "8412"
}

### Clear all workers
DELETE http://localhost:8080/api/workers


### List all workers
GET http://localhost:8080/api/workers


### Delete Jobs
DELETE http://localhost:8080/api/jobs


### Create job
POST http://localhost:8080/api/jobs
Content-Type: application/json

{
    "name": "jobname",
    "priority": 100,
    "tasks": [
        {
        "name": "taskname1",
        "command": "testcommand1"
        },
        {
        "name": "taskname2",
        "command": "testcommand2"
        } 
    ]
}

### Create job 
POST http://localhost:8080/api/jobs
Content-Type: application/json

{
    "name": "ping test",
    "priority": 200,
    "tasks": [
        {
        "name": "ping 1",
        "command": "ping -c 5 google.com"
        },
        {
        "name": "ping 2",
        "command": "ping -c 2 8.8.8.8"
        },
        {
        "name": "ping 3",
        "command": "ping -c 4 127.0.0.1"
        },
        {
        "name": "timeout error",
        "command": "timeout"
        } 
    ]
}
